# Claude CLI OAuth authentication (required)
# Get your token from ~/.claude/.credentials.json → claudeAiOauth.accessToken
CLAUDE_CODE_OAUTH_TOKEN=your-oauth-access-token-here

# Optional: use refresh token instead (longer-lived)
# CLAUDE_CODE_OAUTH_REFRESH_TOKEN=your-refresh-token-here
# CLAUDE_CODE_OAUTH_SCOPES=user:inference

# Optional: restrict CORS to your Vercel domain
# ALLOWED_ORIGINS=https://clash-of-prompt.vercel.app

# Optional: Gemini image generation
# GEMINI_API_KEY=your-gemini-api-key-here

# Server port (Fly.io sets this automatically)
PORT=8080
